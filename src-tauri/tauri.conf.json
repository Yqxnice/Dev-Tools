{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dev Tools",
  "version": "0.1.0",
  "identifier": "com.devtools.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Dev Tools",
        "width": 850,
        "height": 640,
        "resizable": true,
        "minWidth": 850,
        "minHeight": 600,
        "devtools": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' http://localhost:1420 ws://localhost:1421;"
    }
  },
  "plugins": {
    "shell": {}
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
